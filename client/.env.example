# React (CRA) — only REACT_APP_* vars are exposed to the browser.
# Do NOT put secret keys here in production builds.

# FastAPI ML service
REACT_APP_PREDICTION_API_URL=http://localhost:5000

# Node API (auth, /trading config + ledger, profile, etc.)
REACT_APP_API_URL=http://localhost:5001

# Binance keys for direct-from-browser portfolio reads. These ship in the
# bundle — see the security note in README.md before using in production.
REACT_APP_BINANCE_API_KEY=
REACT_APP_BINANCE_API_SECRET=
