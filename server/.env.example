# Node API
APP_PORT=5001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000
SOCKET_PORT=

# Database (MySQL via Sequelize)
DB_NAME=quantumchain
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1

# Auth
JWT_SECRET_KEY=change-me
DATABASE_SERVER_JWT_SECRET_KEY=change-me

# Developer credentials (optional)
DEVELOPER_USERNAME=
DEVELOPER_PASSWORD=

# AI Auto-Trade engine
AUTO_TRADE_ENABLED=true
AUTO_TRADE_TICK_MS=300000
PREDICTION_API_URL=http://localhost:5000

# Phase 4 live execution. Default off — flipping to true on its own is not
# enough; the engine also requires per-user re-auth ACK and tested keys.
ALLOW_LIVE_TRADING=false
LIVE_ACK_TTL_HOURS=24

# Encryption master key for the API-keys vault (AES-256-GCM).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this value invalidates every previously-encrypted key blob.
KEY_VAULT_MASTER_KEY=

# Optional Redis URL for the distributed circuit-breaker state (and any
# future shared cache use). If unset, the breaker stays in-process.
# REDIS_URL=redis://localhost:6379/0

# Circuit breaker tuning (defaults in code if unset).
# CB_FAILURE_THRESHOLD=5
# CB_OPEN_MS=600000
# CB_ENTRY_TTL_SEC=3600
