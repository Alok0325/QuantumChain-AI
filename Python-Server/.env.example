# Binance API credentials (used by model_trainer.py to fetch klines)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Anthropic Claude — powers /rationale
# Without this the endpoint returns a deterministic offline fallback.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# FastAPI
PORT=5000
RELOAD=true
LOG_LEVEL=INFO
# Comma-separated list of allowed browser origins
CLIENT_ORIGIN=http://localhost:3000,http://localhost:3002

# Forecasting backend.
#   "xgb"      — default, ~5 MB install, fast.
#   "lstm"     — legacy. Requires requirements-lstm.txt; ~4 GB; Py ≤3.12 only.
#   "ensemble" — blend XGB + LSTM weighted by recent rolling accuracy.
#                Falls back to whichever single backend is available.
MODEL_BACKEND=xgb

# Optional: REDIS_URL for distributed news cache. Falls back to in-memory.
# REDIS_URL=redis://localhost:6379/0
